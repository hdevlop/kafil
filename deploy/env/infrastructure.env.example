# Copy to /opt/kafil/env/infrastructure.env, chmod 0600, and replace placeholders.
COMPOSE_PROJECT_NAME=kafil
KAFIL_IMAGE=ghcr.io/hdevlop/kafil:sha-REPLACE_WITH_FULL_40_CHARACTER_GIT_SHA
KAFIL_HOSTNAME=demo.example.com
ACME_EMAIL=ops@example.com
KAFIL_LOOPBACK_PORT=3300
KAFIL_STORAGE_HOST_PATH=/srv/kafil/storage-demo
POSTGRES_DB=kafil_demo
POSTGRES_USER=kafil
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DATABASE_PASSWORD
# Optional until Kafil's application-level Redis contract is enabled.
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD
# Set COMPOSE_PROFILES=edge only on a host where Compose owns ports 80/443.
# This VPS already has host Caddy, so leave COMPOSE_PROFILES unset.
