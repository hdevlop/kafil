# Copy to /opt/kafil/env/app.env, chmod 0600, and replace every placeholder.
DATABASE_URL=postgresql://kafil:REPLACE_WITH_DATABASE_PASSWORD@postgres:5432/kafil_demo
FRONTEND_URL=https://demo.example.com
JWT_ACCESS_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
JWT_REFRESH_SECRET=REPLACE_WITH_AT_LEAST_32_DIFFERENT_RANDOM_CHARACTERS
NAJM_ENCRYPTION_KEY=REPLACE_WITH_EXACTLY_64_HEX_CHARACTERS
KAFIL_ADMIN_EMAIL=admin@example.com
KAFIL_ADMIN_PASSWORD=REPLACE_WITH_STRONG_DEMO_ADMIN_PASSWORD
KAFIL_STORAGE_PATH=/srv/kafil/storage
LOG_FORMAT=json
LOG_LEVEL=info
NO_COLOR=1
NEXT_PUBLIC_FORM_FILL_ENABLED=false
EMAIL_PROVIDER=REPLACE_WITH_NON_CONSOLE_PROVIDER
EMAIL_DEFAULT_FROM=Kafil Demo <no-reply@example.com>
# Provider-specific email values belong here, for example RESEND_API_KEY or
# SMTP_HOST, SMTP_PORT, SMTP_SECURE, SMTP_USER, and SMTP_PASS.
# Redis is optional and must be enabled only after the installed Najm contract
# is wired and tested.
