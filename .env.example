DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kafil

KAFIL_ADMIN_EMAIL=admin@admin.com
KAFIL_ADMIN_PASSWORD=Kafil2006

JWT_ACCESS_SECRET=replace-this-development-access-secret-before-production
JWT_REFRESH_SECRET=replace-this-development-refresh-secret-before-production
NAJM_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
FRONTEND_URL=http://localhost:3000

# Kafil defaults to readable logs. Set this to json for log aggregation.
LOG_FORMAT=pretty

# Safe local default. Production should select a real provider and sender.
EMAIL_PROVIDER=console
EMAIL_DEFAULT_FROM="Kafil <noreply@example.org>"

# Resend example:
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_replace_me

# SMTP example:
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.example.org
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=replace_me
# SMTP_PASS=replace_me
