{
  "name": "@kafil/workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "najm-core": "2.0.3"
  },
  "scripts": {
    "dev": "bun --env-file=.env -e \"const child=Bun.spawn({cmd:['bun','run','--cwd','apps/web','dev'],stdout:'inherit',stderr:'inherit',stdin:'inherit'}); process.exit(await child.exited);\"",
    "dev:https": "bun --env-file=.env -e \"const child=Bun.spawn({cmd:['bun','run','--cwd','apps/web','dev','--experimental-https'],stdout:'inherit',stderr:'inherit',stdin:'inherit'}); process.exit(await child.exited);\"",
    "start:https": "bun --env-file=.env scripts/start-local-https.ts",
    "preview:https": "bun run build && bun run start:https",
    "build": "bun --env-file=.env -e \"const child=Bun.spawnSync({cmd:['bun','run','--cwd','apps/web','build'],stdout:'inherit',stderr:'inherit'}); process.exit(child.exitCode);\"",
    "start": "bun --env-file=.env -e \"const child=Bun.spawn({cmd:['bun','run','--cwd','apps/web','start'],stdout:'inherit',stderr:'inherit',stdin:'inherit'}); process.exit(await child.exited);\"",
    "lint": "bun run --cwd apps/web lint && bun run --cwd packages/server lint && bun run --cwd packages/seed lint",
    "typecheck": "bun run --cwd apps/web typecheck && bun run --cwd packages/server typecheck && bun run --cwd packages/seed typecheck",
    "test": "bun run --cwd apps/web test && bun run --cwd packages/server test && bun run --cwd packages/seed test",
    "test:db": "bun --env-file=.env -e \"const child=Bun.spawnSync({cmd:['bun','run','--cwd','packages/server','test:db'],env:{...process.env,KAFIL_RUN_DB_INTEGRATION:'1'},stdout:'inherit',stderr:'inherit'}); process.exit(child.exitCode);\"",
    "check": "bun run lint && bun run typecheck && bun run test && bun run build",
    "db:generate": "bun --env-file=.env -e \"const child=Bun.spawnSync({cmd:['bun','run','--cwd','packages/server','db:generate'],stdout:'inherit',stderr:'inherit'}); process.exit(child.exitCode);\"",
    "db:migrate": "bun --env-file=.env -e \"const child=Bun.spawnSync({cmd:['bun','run','--cwd','packages/server','db:migrate'],stdout:'inherit',stderr:'inherit'}); process.exit(child.exitCode);\"",
    "db:studio": "bun --env-file=.env -e \"const child=Bun.spawnSync({cmd:['bun','run','--cwd','packages/server','db:studio'],stdout:'inherit',stderr:'inherit'}); process.exit(child.exitCode);\"",
    "seed": "bun --cwd packages/seed --env-file=../../.env src/cli.ts",
    "seed:full": "bun --cwd packages/seed --env-file=../../.env src/cli.ts full --yes",
    "seed:demo": "bun --cwd packages/seed --env-file=../../.env src/cli.ts demo",
    "seed:images": "bun --cwd packages/seed --env-file=../../.env src/cli.ts images",
    "seed:migrate": "bun --env-file=.env -e \"const child=Bun.spawnSync({cmd:['bun','run','--cwd','packages/seed','seed:migrate'],stdout:'inherit',stderr:'inherit'}); process.exit(child.exitCode);\"",
    "seed:admin": "bun --env-file=.env -e \"const child=Bun.spawnSync({cmd:['bun','run','--cwd','packages/seed','seed:admin'],stdout:'inherit',stderr:'inherit'}); process.exit(child.exitCode);\"",
    "seed:verify": "bun --env-file=.env -e \"const child=Bun.spawnSync({cmd:['bun','run','--cwd','packages/seed','seed:verify'],stdout:'inherit',stderr:'inherit'}); process.exit(child.exitCode);\"",
    "setup": "bun --cwd packages/seed --env-file=../../.env src/cli.ts setup --yes"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/node": "20.19.14",
    "eslint": "9.36.0",
    "eslint-config-next": "16.2.10",
    "typescript-eslint": "8.64.0",
    "typescript": "5.9.2"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ],
  "dependencies": {
    "@clack/core": "^1.4.3",
    "@clack/prompts": "^1.7.0",
    "najm-core": "^2.0.3",
    "najm-kit": "^2.1.23"
  }
}
